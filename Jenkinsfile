pipeline {
    agent any

    stages {
        stage('Hello') {
            steps {
                echo 'Hello World'
                echo 'first step'
                echo 'this is a jenkins file'
            }
        }
        stage('New Stage') {
            steps {
                echo 'This is another test'
                echo 'second step'
                echo 'this is a jenkins file'
            }
    }
}
